# ── Ryse backend / auth / sync ────────────────────────────────────────────────
# Copy to `.env.local` for local dev (`vercel dev`), and set the same vars in
# the Vercel project dashboard (Settings → Environment Variables) for deploys.

# Clerk — https://dashboard.clerk.com → your app → API Keys
# The publishable key is exposed to the browser (must be prefixed VITE_).
VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# Neon Postgres — added automatically when you install the Neon integration from
# the Vercel Marketplace (it sets DATABASE_URL / POSTGRES_URL on the project).
# For local dev, paste your Neon connection string here.
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Optional: where the web client should send /api requests. Leave empty for
# same-origin (web + `vercel dev`). Capacitor native builds (iOS/Android) MUST
# set this to the deployed origin, e.g. https://your-app.vercel.app
VITE_API_BASE_URL=
